      <control><group>[Channel1]</group><status>0x91</status><midino>77</midino>
        <options><script-binding/></options><key>NS7III.pad</key></control>
      <control><group>[Channel1]</group><status>0x91</status><midino>78</midino>
        <options><script-binding/></options><key>NS7III.pad</key></control>

      <control><group>[Channel2]</group><status>0x92</status><midino>71</midino>
        <options><script-binding/></options><key>NS7III.pad</key></control>
      <control><group>[Channel2]</group><status>0x92</status><midino>72</midino>
        <options><script-binding/></options><key>NS7III.pad</key></control>
      <control><group>[Channel2]</group><status>0x92</status><midino>73</midino>
        <options><script-binding/></options><key>NS7III.pad</key></control>
      <control><group>[Channel2]</group><status>0x92</status><midino>74</midino>
        <options><script-binding/></options><key>NS7III.pad</key></control>
      <control><group>[Channel2]</group><status>0x92</status><midino>75</midino>
        <options><script-binding/></options><key>NS7III.pad</key></control>
