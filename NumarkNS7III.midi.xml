<?xml version="1.0" encoding="utf-8"?>
<!--
  Numark NS7III — Mixxx 2.4+ MIDI mapping
  Derived from djcmd ns7_iii.map / djcmd_config.h + live MIDI capture

  Hardware layout:
    Ch1  (0xB0/0x90) global: crossfader, master/booth vol, library, FX, deck-sel
    Ch2  (0xB1/0x91) left platter:  Deck A (default) / Deck C (layer 2)
    Ch3  (0xB2/0x92) right platter: Deck B (default) / Deck D (layer 2)

  Layer switching (deck_sel buttons, Ch1 NoteOn):
    note 2 → left=A    note 3 → right=B
    note 4 → left=C    note 5 → right=D
  Hardware automatically shifts ALL button/pad MIDI messages to the active deck channel:
    Deck A=0x91  Deck B=0x92  Deck C=0x93  Deck D=0x94
  Physical encoder data (jog CC0, pitch bend, pitch CC1) stays on 0xB1/0xE1 (left)
  and 0xB2/0xE2 (right) regardless of active layer.

  Note reference (confirmed by live MIDI capture):
    49 = Load         50 = Sync          51 = Cue          52 = Play
    53 = Shift        59 = Nudge Back    60 = Nudge Fwd    63 = Loop Out
    68 = Slip         69 = Param Left    70 = Param Right  71-78 = Pads 1-8
    79 = Pad Cues     80 = Pad Roll      81 = Loop Toggle

  LEDs:
    Transport/hotcue LEDs managed by engine.makeConnection in NumarkNS7III.js.
    Only FX button LEDs (not layer-dependent) use XML <output> entries.

  Motor protocol (confirmed from djcmd_config.h):
    Cold-init: CC71/74/75/76/77=0 + pad LED regs CC78-85 on Ch1 (2-3x each)
    Start: CC75=0 Ch1, CC65=127 ChN, CC69=0 ChN (FORWARD),
           ramp: CC73=0→100 ChN, CC105=64 ChN, CC74=0→5 Ch1 (18 steps @ 50ms)
    Stop:  CC73=0 ChN, CC66=127 ChN
    NOTE:  CC68 is the BRAKE register — NOT sent (CFG_MOTOR_BRAKE_VAL=0)

  EQ CC numbers (hardware-probed, from ns7_iii.map):
    Ch1 strip: low=9  mid=10 high=11   Ch2 strip: low=14 mid=15 high=16
    Ch3 strip: low=20 mid=21 high=22   Ch4 strip: low=25 mid=26 high=27
    Physical strip order left→right: Ch3, Ch1, Ch2, Ch4
-->

<MixxxMIDIPreset schemaVersion="1" mixxxVersion="2.4+">
  <info>
    <name>Numark NS7III</name>
    <author>djcmd project</author>
    <description>NS7III 4-deck mapping with motor control and layer switching</description>
  </info>

  <controller id="NS7 III">
    <scriptfiles>
      <file filename="NumarkNS7III.js" functionprefix="NS7III"/>
    </scriptfiles>

    <controls>
      <!-- ── Mixer (channel-independent, fixed routing) ──────────────────── -->
      <control><group>[Master]</group><key>crossfader</key>
        <status>0xB0</status><midino>7</midino><options><normal/></options></control>
      <control><group>[Master]</group><key>gain</key>
        <status>0xB0</status><midino>66</midino><options><normal/></options></control>
      <control><group>[Master]</group><key>booth_gain</key>
        <status>0xB0</status><midino>67</midino><options><normal/></options></control>

      <!-- Deck A (Channel1) EQ / vol / gain / filter — physical strip CC Ch1 -->
      <control><group>[Channel1]</group><key>volume</key>
        <status>0xB0</status><midino>8</midino><options><normal/></options></control>
      <control><group>[Channel1]</group><key>pregain</key>
        <status>0xB0</status><midino>12</midino><options><normal/></options></control>
      <control><group>[Channel1]</group><key>filterLow</key>
        <status>0xB0</status><midino>9</midino><options><normal/></options></control>
      <control><group>[Channel1]</group><key>filterMid</key>
        <status>0xB0</status><midino>10</midino><options><normal/></options></control>
      <control><group>[Channel1]</group><key>filterHigh</key>
        <status>0xB0</status><midino>11</midino><options><normal/></options></control>
      <control><group>[Channel1]</group><key>super1</key>
        <status>0xB0</status><midino>91</midino><options><normal/></options></control>

      <!-- Deck B (Channel2) EQ / vol / gain / filter -->
      <control><group>[Channel2]</group><key>volume</key>
        <status>0xB0</status><midino>13</midino><options><normal/></options></control>
      <control><group>[Channel2]</group><key>pregain</key>
        <status>0xB0</status><midino>17</midino><options><normal/></options></control>
      <control><group>[Channel2]</group><key>filterLow</key>
        <status>0xB0</status><midino>14</midino><options><normal/></options></control>
      <control><group>[Channel2]</group><key>filterMid</key>
        <status>0xB0</status><midino>15</midino><options><normal/></options></control>
      <control><group>[Channel2]</group><key>filterHigh</key>
        <status>0xB0</status><midino>16</midino><options><normal/></options></control>
      <control><group>[Channel2]</group><key>super1</key>
        <status>0xB0</status><midino>92</midino><options><normal/></options></control>

      <!-- Deck C (Channel3) EQ / vol / gain / filter -->
      <control><group>[Channel3]</group><key>volume</key>
        <status>0xB0</status><midino>19</midino><options><normal/></options></control>
      <control><group>[Channel3]</group><key>pregain</key>
        <status>0xB0</status><midino>23</midino><options><normal/></options></control>
      <control><group>[Channel3]</group><key>filterLow</key>
        <status>0xB0</status><midino>20</midino><options><normal/></options></control>
      <control><group>[Channel3]</group><key>filterMid</key>
        <status>0xB0</status><midino>21</midino><options><normal/></options></control>
      <control><group>[Channel3]</group><key>filterHigh</key>
        <status>0xB0</status><midino>22</midino><options><normal/></options></control>
      <control><group>[Channel3]</group><key>super1</key>
        <status>0xB0</status><midino>90</midino><options><normal/></options></control>

      <!-- Deck D (Channel4) EQ / vol / gain / filter -->
      <control><group>[Channel4]</group><key>volume</key>
        <status>0xB0</status><midino>24</midino><options><normal/></options></control>
      <control><group>[Channel4]</group><key>pregain</key>
        <status>0xB0</status><midino>28</midino><options><normal/></options></control>
      <control><group>[Channel4]</group><key>filterLow</key>
        <status>0xB0</status><midino>25</midino><options><normal/></options></control>
      <control><group>[Channel4]</group><key>filterMid</key>
        <status>0xB0</status><midino>26</midino><options><normal/></options></control>
      <control><group>[Channel4]</group><key>filterHigh</key>
        <status>0xB0</status><midino>27</midino><options><normal/></options></control>
      <control><group>[Channel4]</group><key>super1</key>
        <status>0xB0</status><midino>93</midino><options><normal/></options></control>

      <!-- ── Library ─────────────────────────────────────────────────────── -->
      <control><group>[Library]</group><key>MoveVertical</key>
        <status>0xB0</status><midino>3</midino><options><selectknob/></options></control>
      <control><group>[Library]</group><key>GoToItem</key>
        <status>0x90</status><midino>8</midino><options><normal/></options></control>
      <control><group>[Library]</group><key>MoveLeft</key>
        <status>0x90</status><midino>6</midino><options><normal/></options></control>
      <control><group>[Library]</group><key>MoveRight</key>
        <status>0x90</status><midino>7</midino><options><normal/></options></control>

      <!-- ── FX buttons (Ch1 NoteOn, notes 15/16/18 = deck A, 19/20/22 = deck B) ── -->
      <!-- btn1/btn2 toggle effect unit enabled; btn3 routes the deck through the unit -->
      <control><group>[EffectRack1_EffectUnit1]</group><key>enabled</key>
        <status>0x90</status><midino>15</midino><options><toggle/></options></control>
      <control><group>[EffectRack1_EffectUnit2]</group><key>enabled</key>
        <status>0x90</status><midino>16</midino><options><toggle/></options></control>
      <control><group>[EffectRack1_EffectUnit1]</group><key>group_[Channel1]_enable</key>
        <status>0x90</status><midino>18</midino><options><toggle/></options></control>
      <control><group>[EffectRack1_EffectUnit3]</group><key>enabled</key>
        <status>0x90</status><midino>19</midino><options><toggle/></options></control>
      <control><group>[EffectRack1_EffectUnit4]</group><key>enabled</key>
        <status>0x90</status><midino>20</midino><options><toggle/></options></control>
      <control><group>[EffectRack1_EffectUnit3]</group><key>group_[Channel2]_enable</key>
        <status>0x90</status><midino>22</midino><options><toggle/></options></control>

      <!-- ── Deck layer selectors (Ch1 NoteOn, notes 2-5) ─────────────────── -->
      <control><group>[Channel1]</group>
        <status>0x90</status><midino>2</midino>
        <options><script-binding/></options>
        <key>NS7III.deckSel1</key></control>
      <control><group>[Channel2]</group>
        <status>0x90</status><midino>3</midino>
        <options><script-binding/></options>
        <key>NS7III.deckSel2</key></control>
      <control><group>[Channel3]</group>
        <status>0x90</status><midino>4</midino>
        <options><script-binding/></options>
        <key>NS7III.deckSel3</key></control>
      <control><group>[Channel4]</group>
        <status>0x90</status><midino>5</midino>
        <options><script-binding/></options>
        <key>NS7III.deckSel4</key></control>

      <!-- ── Jog wheels (physical channels — always 0xB1/0xE1 left, 0xB2/0xE2 right) ── -->
      <!-- CC0 = coarse absolute position; Pitch Bend = fine absolute position -->
      <!-- Touch is inferred from PB activity (no CC2 touch on NS7III hardware) -->
      <control><group>[Channel1]</group>
        <status>0xB1</status><midino>0</midino>
        <options><script-binding/></options>
        <key>NS7III.jogSpin</key></control>
      <control><group>[Channel1]</group>
        <status>0xE1</status><midino>0</midino>
        <options><script-binding/></options>
        <key>NS7III.jogPB</key></control>
      <control><group>[Channel2]</group>
        <status>0xB2</status><midino>0</midino>
        <options><script-binding/></options>
        <key>NS7III.jogSpin</key></control>
      <control><group>[Channel2]</group>
        <status>0xE2</status><midino>0</midino>
        <options><script-binding/></options>
        <key>NS7III.jogPB</key></control>

      <!-- ── Pitch faders (physical channels — always 0xB1 left, 0xB2 right) ── -->
      <!-- pitchA/pitchB route to whichever virtual deck is active on that platter -->
      <control><group>[Channel1]</group>
        <status>0xB1</status><midino>1</midino>
        <options><script-binding/></options>
        <key>NS7III.pitchA</key></control>
      <control><group>[Channel2]</group>
        <status>0xB2</status><midino>1</midino>
        <options><script-binding/></options>
        <key>NS7III.pitchB</key></control>

      <!-- ── Shift (note 53) — all 4 deck channels ─────────────────────────── -->
      <control><group>[Channel1]</group>
        <status>0x91</status><midino>53</midino>
        <options><script-binding/></options>
        <key>NS7III.shift</key></control>
      <control><group>[Channel2]</group>
        <status>0x92</status><midino>53</midino>
        <options><script-binding/></options>
        <key>NS7III.shift</key></control>
      <control><group>[Channel3]</group>
        <status>0x93</status><midino>53</midino>
        <options><script-binding/></options>
        <key>NS7III.shift</key></control>
      <control><group>[Channel4]</group>
        <status>0x94</status><midino>53</midino>
        <options><script-binding/></options>
        <key>NS7III.shift</key></control>

      <!-- ── Play (note 52) — all 4 deck channels ──────────────────────────── -->
      <control><group>[Channel1]</group>
        <status>0x91</status><midino>52</midino>
        <options><script-binding/></options>
        <key>NS7III.play</key></control>
      <control><group>[Channel2]</group>
        <status>0x92</status><midino>52</midino>
        <options><script-binding/></options>
        <key>NS7III.play</key></control>
      <control><group>[Channel3]</group>
        <status>0x93</status><midino>52</midino>
        <options><script-binding/></options>
        <key>NS7III.play</key></control>
      <control><group>[Channel4]</group>
        <status>0x94</status><midino>52</midino>
        <options><script-binding/></options>
        <key>NS7III.play</key></control>

      <!-- ── Cue (note 51) — all 4 deck channels ───────────────────────────── -->
      <control><group>[Channel1]</group>
        <status>0x91</status><midino>51</midino>
        <options><script-binding/></options>
        <key>NS7III.cue</key></control>
      <control><group>[Channel2]</group>
        <status>0x92</status><midino>51</midino>
        <options><script-binding/></options>
        <key>NS7III.cue</key></control>
      <control><group>[Channel3]</group>
        <status>0x93</status><midino>51</midino>
        <options><script-binding/></options>
        <key>NS7III.cue</key></control>
      <control><group>[Channel4]</group>
        <status>0x94</status><midino>51</midino>
        <options><script-binding/></options>
        <key>NS7III.cue</key></control>

      <!-- ── Sync (note 50, confirmed by MIDI capture) — all 4 deck channels ── -->
      <control><group>[Channel1]</group>
        <status>0x91</status><midino>50</midino>
        <options><script-binding/></options>
        <key>NS7III.sync</key></control>
      <control><group>[Channel2]</group>
        <status>0x92</status><midino>50</midino>
        <options><script-binding/></options>
        <key>NS7III.sync</key></control>
      <control><group>[Channel3]</group>
        <status>0x93</status><midino>50</midino>
        <options><script-binding/></options>
        <key>NS7III.sync</key></control>
      <control><group>[Channel4]</group>
        <status>0x94</status><midino>50</midino>
        <options><script-binding/></options>
        <key>NS7III.sync</key></control>

      <!-- ── Slip (note 68) — all 4 deck channels ──────────────────────────── -->
      <control><group>[Channel1]</group>
        <status>0x91</status><midino>68</midino>
        <options><script-binding/></options>
        <key>NS7III.slip</key></control>
      <control><group>[Channel2]</group>
        <status>0x92</status><midino>68</midino>
        <options><script-binding/></options>
        <key>NS7III.slip</key></control>
      <control><group>[Channel3]</group>
        <status>0x93</status><midino>68</midino>
        <options><script-binding/></options>
        <key>NS7III.slip</key></control>
      <control><group>[Channel4]</group>
        <status>0x94</status><midino>68</midino>
        <options><script-binding/></options>
        <key>NS7III.slip</key></control>

      <!-- ── Bleep / Reverse switch (notes 62, 63) — all 4 deck channels ────── -->
      <control><group>[Channel1]</group>
        <status>0x91</status><midino>62</midino>
        <options><script-binding/></options>
        <key>NS7III.bleep</key></control>
      <control><group>[Channel1]</group>
        <status>0x91</status><midino>63</midino>
        <options><script-binding/></options>
        <key>NS7III.reverse</key></control>
      <control><group>[Channel2]</group>
        <status>0x92</status><midino>62</midino>
        <options><script-binding/></options>
        <key>NS7III.bleep</key></control>
      <control><group>[Channel2]</group>
        <status>0x92</status><midino>63</midino>
        <options><script-binding/></options>
        <key>NS7III.reverse</key></control>
      <control><group>[Channel3]</group>
        <status>0x93</status><midino>62</midino>
        <options><script-binding/></options>
        <key>NS7III.bleep</key></control>
      <control><group>[Channel3]</group>
        <status>0x93</status><midino>63</midino>
        <options><script-binding/></options>
        <key>NS7III.reverse</key></control>
      <control><group>[Channel4]</group>
        <status>0x94</status><midino>62</midino>
        <options><script-binding/></options>
        <key>NS7III.bleep</key></control>
      <control><group>[Channel4]</group>
        <status>0x94</status><midino>63</midino>
        <options><script-binding/></options>
        <key>NS7III.reverse</key></control>

      <!-- ── Loop Toggle (note 81) — all 4 deck channels ───────────────────── -->
      <control><group>[Channel1]</group>
        <status>0x91</status><midino>81</midino>
        <options><script-binding/></options>
        <key>NS7III.loopToggle</key></control>
      <control><group>[Channel2]</group>
        <status>0x92</status><midino>81</midino>
        <options><script-binding/></options>
        <key>NS7III.loopToggle</key></control>
      <control><group>[Channel3]</group>
        <status>0x93</status><midino>81</midino>
        <options><script-binding/></options>
        <key>NS7III.loopToggle</key></control>
      <control><group>[Channel4]</group>
        <status>0x94</status><midino>81</midino>
        <options><script-binding/></options>
        <key>NS7III.loopToggle</key></control>

      <!-- ── Nudge Fwd/Back (notes 60/59) — all 4 deck channels ───────────── -->
      <control><group>[Channel1]</group>
        <status>0x91</status><midino>60</midino>
        <options><script-binding/></options>
        <key>NS7III.nudgeFwd</key></control>
      <control><group>[Channel1]</group>
        <status>0x91</status><midino>59</midino>
        <options><script-binding/></options>
        <key>NS7III.nudgeBack</key></control>
      <control><group>[Channel2]</group>
        <status>0x92</status><midino>60</midino>
        <options><script-binding/></options>
        <key>NS7III.nudgeFwd</key></control>
      <control><group>[Channel2]</group>
        <status>0x92</status><midino>59</midino>
        <options><script-binding/></options>
        <key>NS7III.nudgeBack</key></control>
      <control><group>[Channel3]</group>
        <status>0x93</status><midino>60</midino>
        <options><script-binding/></options>
        <key>NS7III.nudgeFwd</key></control>
      <control><group>[Channel3]</group>
        <status>0x93</status><midino>59</midino>
        <options><script-binding/></options>
        <key>NS7III.nudgeBack</key></control>
      <control><group>[Channel4]</group>
        <status>0x94</status><midino>60</midino>
        <options><script-binding/></options>
        <key>NS7III.nudgeFwd</key></control>
      <control><group>[Channel4]</group>
        <status>0x94</status><midino>59</midino>
        <options><script-binding/></options>
        <key>NS7III.nudgeBack</key></control>

      <!-- ── Load (note 49) — all 4 deck channels ──────────────────────────── -->
      <control><group>[Channel1]</group>
        <status>0x91</status><midino>49</midino>
        <options><script-binding/></options>
        <key>NS7III.load</key></control>
      <control><group>[Channel2]</group>
        <status>0x92</status><midino>49</midino>
        <options><script-binding/></options>
        <key>NS7III.load</key></control>
      <control><group>[Channel3]</group>
        <status>0x93</status><midino>49</midino>
        <options><script-binding/></options>
        <key>NS7III.load</key></control>
      <control><group>[Channel4]</group>
        <status>0x94</status><midino>49</midino>
        <options><script-binding/></options>
        <key>NS7III.load</key></control>

      <!-- ── Parameter Left/Right (notes 69/70 = loop halve/double) ─────────── -->
      <!-- All 4 deck channels -->
      <control><group>[Channel1]</group>
        <status>0x91</status><midino>69</midino>
        <options><script-binding/></options>
        <key>NS7III.paramLeft</key></control>
      <control><group>[Channel1]</group>
        <status>0x91</status><midino>70</midino>
        <options><script-binding/></options>
        <key>NS7III.paramRight</key></control>
      <control><group>[Channel2]</group>
        <status>0x92</status><midino>69</midino>
        <options><script-binding/></options>
        <key>NS7III.paramLeft</key></control>
      <control><group>[Channel2]</group>
        <status>0x92</status><midino>70</midino>
        <options><script-binding/></options>
        <key>NS7III.paramRight</key></control>
      <control><group>[Channel3]</group>
        <status>0x93</status><midino>69</midino>
        <options><script-binding/></options>
        <key>NS7III.paramLeft</key></control>
      <control><group>[Channel3]</group>
        <status>0x93</status><midino>70</midino>
        <options><script-binding/></options>
        <key>NS7III.paramRight</key></control>
      <control><group>[Channel4]</group>
        <status>0x94</status><midino>69</midino>
        <options><script-binding/></options>
        <key>NS7III.paramLeft</key></control>
      <control><group>[Channel4]</group>
        <status>0x94</status><midino>70</midino>
        <options><script-binding/></options>
        <key>NS7III.paramRight</key></control>

      <!-- ── Pads 1-8 (notes 71-78) — all 4 deck channels ─────────────────── -->
      <!-- pad() derives pad number as control-70; mode from padMode[side] -->
      <control><group>[Channel1]</group><status>0x91</status><midino>71</midino>
        <options><script-binding/></options><key>NS7III.pad</key></control>
      <control><group>[Channel1]</group><status>0x91</status><midino>72</midino>
        <options><script-binding/></options><key>NS7III.pad</key></control>
      <control><group>[Channel1]</group><status>0x91</status><midino>73</midino>
        <options><script-binding/></options><key>NS7III.pad</key></control>
